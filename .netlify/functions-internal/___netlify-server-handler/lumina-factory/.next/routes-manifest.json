    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dna-profiles/new",
      "regex": "^/dna\\-profiles/new(?:/)?$",
      "routeKeys": {},
