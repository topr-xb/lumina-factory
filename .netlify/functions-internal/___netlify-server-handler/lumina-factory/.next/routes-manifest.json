      "namedRegex": "^/api/admin/users(?:/)?$"
    },
    {
      "page": "/api/batches",
      "regex": "^/api/batches(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/batches(?:/)?$"
    },
    {
      "page": "/api/cost",
      "regex": "^/api/cost(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/cost(?:/)?$"
    },
    {
      "page": "/api/dna-profiles",
      "regex": "^/api/dna\\-profiles(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/dna\\-profiles(?:/)?$"
    },
    {
      "page": "/api/upload",
      "regex": "^/api/upload(?:/)?$",
      "routeKeys": {},
